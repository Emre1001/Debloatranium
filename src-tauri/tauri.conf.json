{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Debloatranium",
  "version": "1.0.0",
  "identifier": "com.emre.debloatranium",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Debloatranium",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "center": true,
        "resizable": true,
        "shadow": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
